PREFIX cim:  <%%CIM_NS%%>

PREFIX md:   <http://iec.ch/TC57/61970-552/ModelDescription/1#>

SELECT * WHERE {
  ?id rdf:type cim:ExcST1A .
  OPTIONAL { ?id cim:ExcitationSystemDynamics.SynchronousMachineDynamics ?synchronousMachineId . }
  OPTIONAL { ?id cim:ExcST1A.tr ?tr . }
  OPTIONAL { ?id cim:ExcST1A.vimax ?vimax . }
  OPTIONAL { ?id cim:ExcST1A.vimin ?vimin . }
  OPTIONAL { ?id cim:ExcST1A.tb ?tb . }
  OPTIONAL { ?id cim:ExcST1A.tc ?tc . }
  OPTIONAL { ?id cim:ExcST1A.ka ?ka . }
  OPTIONAL { ?id cim:ExcST1A.ta ?ta . }
  OPTIONAL { ?id cim:ExcST1A.vamax ?vamax . }
  OPTIONAL { ?id cim:ExcST1A.vamin ?vamin . }
  OPTIONAL { ?id cim:ExcST1A.vrmax ?vrmax . }
  OPTIONAL { ?id cim:ExcST1A.vrmin ?vrmin . }
  OPTIONAL { ?id cim:ExcST1A.kc ?kc . }
  OPTIONAL { ?id cim:ExcST1A.kf ?kf . }
  OPTIONAL { ?id cim:ExcST1A.tf ?tf . }
  OPTIONAL { ?id cim:ExcST1A.pssin ?pssin . }
  OPTIONAL { ?id cim:ExcST1A.ilr ?ilr . }
  OPTIONAL { ?id cim:ExcST1A.klr ?klr . }
}
