PREFIX cim:  <%%CIM_NS%%>

PREFIX md:   <http://iec.ch/TC57/61970-552/ModelDescription/1#>

SELECT * WHERE {
  ?id rdf:type cim:ExcIEEEAC3A .
  OPTIONAL { ?id cim:ExcitationSystemDynamics.SynchronousMachineDynamics ?synchronousMachineId . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.tr ?tr . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.tb ?tb . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.tc ?tc . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.ka ?ka . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.ta ?ta . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.vamax ?vamax . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.vamin ?vamin . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.te ?te . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.vemin ?vemin . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.kr ?kr . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.kf ?kf . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.tf ?tf . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.kc ?kc . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.kd ?kd . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.ke ?ke . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.kn ?kn . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.vfemax ?vfemax . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.efdn ?efdn . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.e1 ?e1 . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.se1 ?se1 . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.e2 ?e2 . }
  OPTIONAL { ?id cim:ExcIEEEAC3A.se2 ?se2 . }
}
