PREFIX cim:  <%%CIM_NS%%>

PREFIX md:   <http://iec.ch/TC57/61970-552/ModelDescription/1#>

SELECT * WHERE {
  ?id rdf:type cim:ExcIEEEAC8B .
  OPTIONAL { ?id cim:ExcitationSystemDynamics.SynchronousMachineDynamics ?synchronousMachineId . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.tr ?tr . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.kpr ?kpr . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.kir ?kir . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.kdr ?kdr . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.tdr ?tdr . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.vrmax ?vrmax . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.vrmin ?vrmin . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.ka ?ka . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.ta ?ta . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.vamax ?vamax . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.vamin ?vamin . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.te ?te . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.ke ?ke . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.vfemax ?vfemax . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.vemin ?vemin . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.kc ?kc . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.kd ?kd . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.e1 ?e1 . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.se1 ?se1 . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.e2 ?e2 . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.se2 ?se2 . }
  OPTIONAL { ?id cim:ExcIEEEAC8B.uelin ?uelin . }
}
